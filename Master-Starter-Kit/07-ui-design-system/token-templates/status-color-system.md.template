## 4. Utility: Status Family Resolver

A helper function that maps any business status string to a family:

```typescript
type StatusFamily =
  | 'success' | 'warning' | 'danger' | 'info'
  | 'neutral' | 'in-progress' | 'queued' | 'special';

const STATUS_FAMILY_MAP: Record<string, StatusFamily> = {
  // Success
  active: 'success',
  delivered: 'success',
  completed: 'success',
  paid: 'success',
  approved: 'success',
  verified: 'success',

  // Warning
  pending_review: 'warning',
  expiring_soon: 'warning',
  needs_attention: 'warning',
  partial: 'warning',

  // Danger
  overdue: 'danger',
  rejected: 'danger',
  failed: 'danger',
  cancelled: 'danger',
  expired: 'danger',
  critical: 'danger',

  // Info
  new: 'info',
  updated: 'info',
  notification: 'info',

  // Neutral
  draft: 'neutral',
  inactive: 'neutral',
  archived: 'neutral',
  unknown: 'neutral',

  // In-Progress
  in_transit: 'in-progress',
  processing: 'in-progress',
  loading: 'in-progress',
  building: 'in-progress',
  dispatched: 'in-progress',

  // Queued
  scheduled: 'queued',
  pending: 'queued',
  waiting: 'queued',
  on_hold: 'queued',
  booked: 'queued',

  // Special
  vip: 'special',
  priority: 'special',
  featured: 'special',
  premium: 'special',
};

export function getStatusFamily(status: string): StatusFamily {
  return STATUS_FAMILY_MAP[status.toLowerCase().replace(/[\s-]/g, '_')] ?? 'neutral';
}
```

