## 2. DotLabel Badge Component Pattern

The DotLabel is the primary component for displaying status. It renders a small
colored dot next to a text label, all wrapped in a pill-shaped badge.

### Structure

```tsx
interface DotLabelProps {
  /** The status family â€” determines all colors */
  family: 'success' | 'warning' | 'danger' | 'info' | 'neutral'
         | 'in-progress' | 'queued' | 'special';
  /** Display text */
  label: string;
  /** Optional size variant */
  size?: 'sm' | 'md';
}

function DotLabel({ family, label, size = 'sm' }: DotLabelProps) {
  return (
    <span
      className={cn(
        'inline-flex items-center gap-1.5 rounded-full font-medium border',
        size === 'sm' ? 'px-2 py-0.5 text-xs' : 'px-2.5 py-1 text-sm',
      )}
      style={{
        backgroundColor: `var(--status-${family}-bg)`,
        color: `var(--status-${family}-text)`,
        borderColor: `var(--status-${family}-border)`,
      }}
    >
      <span
        className="shrink-0 rounded-full w-1.5 h-1.5"
        style={{ backgroundColor: `var(--status-${family}-dot)` }}
      />
      {label}
    </span>
  );
}
```

### Usage Examples

```tsx
<DotLabel family="success" label="Active" />
<DotLabel family="danger" label="Overdue" />
<DotLabel family="in-progress" label="In Transit" />
<DotLabel family="queued" label="Scheduled" />
<DotLabel family="special" label="VIP" />
```

