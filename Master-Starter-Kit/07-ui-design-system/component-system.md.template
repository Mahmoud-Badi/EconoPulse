## 4. Composition Pattern (Compound Components)

For complex components with multiple related parts:

```tsx
// DataTable compound component
import { createContext, useContext } from 'react';

// 1. Create shared context
interface DataTableContextValue<T> {
  data: T[];
  columns: ColumnDef<T>[];
  sorting: SortingState;
  onSortingChange: (sorting: SortingState) => void;
}

const DataTableContext = createContext<DataTableContextValue<unknown> | null>(null);

function useDataTable() {
  const ctx = useContext(DataTableContext);
  if (!ctx) throw new Error('useDataTable must be used within DataTable');
  return ctx;
}

// 2. Root component provides context
function DataTableRoot<T>({ data, columns, children }: DataTableRootProps<T>) {
  const [sorting, setSorting] = useState<SortingState>([]);

  return (
    <DataTableContext.Provider value={{ data, columns, sorting, onSortingChange: setSorting }}>
      <div className="rounded-lg border border-border">{children}</div>
    </DataTableContext.Provider>
  );
}

// 3. Sub-components consume context
function DataTableHeader() {
  const { columns, sorting, onSortingChange } = useDataTable();
  return <thead>...</thead>;
}

function DataTableBody() {
  const { data, columns } = useDataTable();
  return <tbody>...</tbody>;
}

function DataTablePagination() { /* ... */ }

// 4. Compose and export
export const DataTable = Object.assign(DataTableRoot, {
  Header: DataTableHeader,
  Body: DataTableBody,
  Pagination: DataTablePagination,
});
```

### Usage

```tsx
<DataTable data={loads} columns={columns}>
  <DataTable.Header />
  <DataTable.Body />
  <DataTable.Pagination />
</DataTable>
```

