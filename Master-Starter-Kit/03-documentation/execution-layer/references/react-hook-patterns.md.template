## Pattern 1: List Hook (Pagination + Search + Filters)

<!-- IF {{QUERY_LIBRARY}} == "@tanstack/react-query" -->
```typescript
import { useQuery, keepPreviousData } from '{{QUERY_LIBRARY}}';
import { {{API_CLIENT}} } from '{{API_CLIENT_PATH}}';

interface Use{{Resource}}ListParams {
  page?: number;
  pageSize?: number;
  search?: string;
  status?: string;
  sortBy?: string;
  sortOrder?: 'asc' | 'desc';
}

export function use{{Resource}}List(params: Use{{Resource}}ListParams = {}) {
  const { page = 1, pageSize = {{DEFAULT_PAGE_SIZE}}, search, status, sortBy, sortOrder } = params;

  return useQuery({
    queryKey: ['{{resourcePlural}}', { page, pageSize, search, status, sortBy, sortOrder }],
    queryFn: async () => {
      const response = await {{API_CLIENT}}.get('/{{apiPrefix}}/{{resourcePlural}}', {
        params: { page, pageSize, search, status, sortBy, sortOrder },
      });
      return response.{{API_ENVELOPE_DATA_KEY}};  // unwrap envelope
    },
    placeholderData: keepPreviousData,  // smooth pagination transitions
  });
}
```
<!-- ENDIF -->

<!-- IF {{QUERY_LIBRARY}} == "swr" -->
```typescript
import useSWR from 'swr';
import { {{API_CLIENT}} } from '{{API_CLIENT_PATH}}';

export function use{{Resource}}List(params: Use{{Resource}}ListParams = {}) {
  const queryString = new URLSearchParams(params as any).toString();
  const key = `/{{apiPrefix}}/{{resourcePlural}}?${queryString}`;

  return useSWR(key, async (url) => {
    const response = await {{API_CLIENT}}.get(url);
    return response.{{API_ENVELOPE_DATA_KEY}};
  }, {
    keepPreviousData: true,
  });
}
```
