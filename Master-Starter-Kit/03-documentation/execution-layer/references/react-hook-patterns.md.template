## Pattern 5: Delete Mutation

```typescript
export function useDelete{{Resource}}() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: async (id: string) => {
      await {{API_CLIENT}}.delete(`/{{apiPrefix}}/{{resourcePlural}}/${id}`);
    },
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['{{resourcePlural}}'] });
    },
  });
}
```

