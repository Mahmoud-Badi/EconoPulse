## Pattern 3: Create Mutation

```typescript
import { useMutation, useQueryClient } from '{{QUERY_LIBRARY}}';

export function useCreate{{Resource}}() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: async (data: Create{{Resource}}Dto) => {
      const response = await {{API_CLIENT}}.post('/{{apiPrefix}}/{{resourcePlural}}', data);
      return response.{{API_ENVELOPE_DATA_KEY}};
    },
    onSuccess: () => {
      // Invalidate the list so it refetches
      queryClient.invalidateQueries({ queryKey: ['{{resourcePlural}}'] });
    },
  });
}
```

---

## Pattern 4: Update Mutation

```typescript
export function useUpdate{{Resource}}() {
  const queryClient = useQueryClient();

  return useMutation({
    mutationFn: async ({ id, data }: { id: string; data: Update{{Resource}}Dto }) => {
      const response = await {{API_CLIENT}}.patch(`/{{apiPrefix}}/{{resourcePlural}}/${id}`, data);
      return response.{{API_ENVELOPE_DATA_KEY}};
    },
    onSuccess: (_, variables) => {
      // Invalidate both the list and the specific item
      queryClient.invalidateQueries({ queryKey: ['{{resourcePlural}}'] });
      queryClient.invalidateQueries({ queryKey: ['{{resourceSingular}}', variables.id] });
    },
  });
}
```

