## Pattern 7: Prefetching (for Hover/Navigation)

```typescript
export function usePrefetch{{Resource}}() {
  const queryClient = useQueryClient();

  return (id: string) => {
    queryClient.prefetchQuery({
      queryKey: ['{{resourceSingular}}', id],
      queryFn: async () => {
        const response = await {{API_CLIENT}}.get(`/{{apiPrefix}}/{{resourcePlural}}/${id}`);
        return response.{{API_ENVELOPE_DATA_KEY}};
      },
      staleTime: 30_000, // don't re-prefetch within 30s
    });
  };
}

// Usage: onMouseEnter on table rows or links
