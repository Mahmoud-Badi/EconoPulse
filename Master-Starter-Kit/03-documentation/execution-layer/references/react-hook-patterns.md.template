## Pattern 6: Infinite Query (Load More / Infinite Scroll)

```typescript
import { useInfiniteQuery } from '{{QUERY_LIBRARY}}';

export function use{{Resource}}Infinite(params: Omit<Use{{Resource}}ListParams, 'page'> = {}) {
  return useInfiniteQuery({
    queryKey: ['{{resourcePlural}}', 'infinite', params],
    queryFn: async ({ pageParam = 1 }) => {
      const response = await {{API_CLIENT}}.get('/{{apiPrefix}}/{{resourcePlural}}', {
        params: { ...params, page: pageParam, pageSize: {{DEFAULT_PAGE_SIZE}} },
      });
      return response.{{API_ENVELOPE_DATA_KEY}};
    },
    getNextPageParam: (lastPage, allPages) => {
      // Assumes meta.total is available in the envelope
      const totalLoaded = allPages.length * {{DEFAULT_PAGE_SIZE}};
      return totalLoaded < lastPage.meta?.total ? allPages.length + 1 : undefined;
    },
    initialPageParam: 1,
  });
}
```

