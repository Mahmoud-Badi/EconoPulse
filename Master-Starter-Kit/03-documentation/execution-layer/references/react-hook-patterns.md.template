## Pattern 2: Detail Hook

```typescript
export function use{{Resource}}(id: string | undefined) {
  return useQuery({
    queryKey: ['{{resourceSingular}}', id],
    queryFn: async () => {
      const response = await {{API_CLIENT}}.get(`/{{apiPrefix}}/{{resourcePlural}}/${id}`);
      return response.{{API_ENVELOPE_DATA_KEY}};
    },
    enabled: !!id,  // don't fetch until we have an ID
  });
}
```

