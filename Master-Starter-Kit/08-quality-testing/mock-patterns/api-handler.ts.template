 *
 * Provides CRUD endpoint handlers for a resource using MSW v2.
 * Replace [resource] with the actual resource name (e.g., carriers, loads).
 *
 * Usage:
 *   import { [resource]Handlers } from './api-handler';
 *   const server = setupServer(...[resource]Handlers);
 *
 * Generated by New-Project-Starter-Kit
 */

<!-- IF {{FRONTEND_FRAMEWORK}} != "none" -->
import { http, HttpResponse } from 'msw';

const API_BASE = '{{API_BASE_URL}}';

// =============================================================================
// Example handlers for a resource
// =============================================================================
export const [resource]Handlers = [
  // ---------------------------------------------------------------------------
  // List
  // ---------------------------------------------------------------------------
  http.get(`${API_BASE}/{{API_PREFIX}}/[resource]s`, () => {
    return HttpResponse.json({
      data: [
        { id: '1', name: 'Test Item 1' },
        { id: '2', name: 'Test Item 2' },
      ],
      meta: { total: 2, page: 1, pageSize: 20 },
    });
  }),

  // ---------------------------------------------------------------------------
  // Get by ID
  // ---------------------------------------------------------------------------
  http.get(`${API_BASE}/{{API_PREFIX}}/[resource]s/:id`, ({ params }) => {
    return HttpResponse.json({
      data: { id: params.id, name: 'Test Item' },
    });
  }),

  // ---------------------------------------------------------------------------
  // Create
  // ---------------------------------------------------------------------------
  http.post(`${API_BASE}/{{API_PREFIX}}/[resource]s`, async ({ request }) => {
    const body = await request.json();
    return HttpResponse.json({
      data: { id: 'new-id', ...body },
    }, { status: 201 });
  }),

  // ---------------------------------------------------------------------------
  // Update
  // ---------------------------------------------------------------------------
  http.patch(`${API_BASE}/{{API_PREFIX}}/[resource]s/:id`, async ({ request, params }) => {
    const body = await request.json();
    return HttpResponse.json({
      data: { id: params.id, ...body },
    });
  }),

  // ---------------------------------------------------------------------------
  // Delete
  // ---------------------------------------------------------------------------
  http.delete(`${API_BASE}/{{API_PREFIX}}/[resource]s/:id`, () => {
    return new HttpResponse(null, { status: 204 });
  }),
];
