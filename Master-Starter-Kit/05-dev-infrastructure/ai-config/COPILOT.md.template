## Import Conventions

```typescript
// Use path aliases -- never use relative paths with more than 2 levels
import { Component } from '{{PATH_ALIAS}}/components/feature/Component';
import { useAuth } from '{{PATH_ALIAS}}/lib/auth';
import { apiClient } from '{{PATH_ALIAS}}/lib/api';

// UI primitives from {{DESIGN_SYSTEM_LIBRARY}}
import { Button } from '{{PATH_ALIAS}}/components/ui/button';

// Domain components from custom library
import { DomainWidget } from '{{PATH_ALIAS}}/components/{{CUSTOM_COMPONENTS_DIR}}/domain-widget';
```

