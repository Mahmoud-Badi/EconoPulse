# Docker Compose for {{PROJECT_NAME}} development infrastructure
# Usage: docker-compose up -d

version: '3.8'

services:
<!-- IF {{DATABASE}} == "postgresql" -->
  postgres:
    image: postgres:16-alpine
    container_name: {{PROJECT_SLUG}}-postgres
    restart: unless-stopped
    ports:
      - '{{DB_PORT}}:5432'
    environment:
      POSTGRES_USER: ${DB_USER:-postgres}
      POSTGRES_PASSWORD: ${DB_PASSWORD:-postgres}
      POSTGRES_DB: ${DB_NAME:-{{PROJECT_SLUG}}}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ['CMD-SHELL', 'pg_isready -U postgres']
      interval: 5s
      timeout: 5s
      retries: 5
<!-- ENDIF -->

<!-- IF {{DATABASE}} == "mysql" -->
  mysql:
    image: mysql:8.0
    container_name: {{PROJECT_SLUG}}-mysql
    restart: unless-stopped
    ports:
      - '{{DB_PORT}}:3306'
    environment:
      MYSQL_ROOT_PASSWORD: ${DB_PASSWORD:-root}
      MYSQL_DATABASE: ${DB_NAME:-{{PROJECT_SLUG}}}
    volumes:
      - mysql_data:/var/lib/mysql
<!-- ENDIF -->

<!-- IF {{DATABASE}} == "mongodb" -->
  mongodb:
    image: mongo:7
    container_name: {{PROJECT_SLUG}}-mongodb
    restart: unless-stopped
    ports:
      - '{{DB_PORT}}:27017'
    environment:
      MONGO_INITDB_ROOT_USERNAME: ${DB_USER:-admin}
      MONGO_INITDB_ROOT_PASSWORD: ${DB_PASSWORD:-password}
    volumes:
      - mongo_data:/data/db
<!-- ENDIF -->

  redis:
    image: redis:7-alpine
    container_name: {{PROJECT_SLUG}}-redis
    restart: unless-stopped
    ports:
      - '{{REDIS_PORT}}:6379'
    command: redis-server --requirepass ${REDIS_PASSWORD:-redis_password}
    volumes:
      - redis_data:/data

volumes:
<!-- IF {{DATABASE}} == "postgresql" -->
  postgres_data:
<!-- ENDIF -->
<!-- IF {{DATABASE}} == "mysql" -->
  mysql_data:
<!-- ENDIF -->
<!-- IF {{DATABASE}} == "mongodb" -->
  mongo_data:
<!-- ENDIF -->
  redis_data:
