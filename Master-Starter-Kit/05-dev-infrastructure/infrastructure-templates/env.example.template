# {{PROJECT_NAME}} — Environment Variables
# Copy this to .env and fill in values

# ═══════════════════════════════════════
# Application
# ═══════════════════════════════════════
NODE_ENV=development
APP_NAME={{PROJECT_NAME}}
APP_URL=http://localhost:{{FRONTEND_PORT}}

# ═══════════════════════════════════════
# Database
# ═══════════════════════════════════════
<!-- IF {{DATABASE}} == "postgresql" -->
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@localhost:{{DB_PORT}}/${DB_NAME}
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME={{PROJECT_SLUG}}
<!-- ENDIF -->
<!-- IF {{DATABASE}} == "mysql" -->
DATABASE_URL=mysql://root:root@localhost:{{DB_PORT}}/{{PROJECT_SLUG}}
<!-- ENDIF -->
<!-- IF {{DATABASE}} == "mongodb" -->
DATABASE_URL=mongodb://admin:password@localhost:{{DB_PORT}}/{{PROJECT_SLUG}}
<!-- ENDIF -->

# ═══════════════════════════════════════
# Redis
# ═══════════════════════════════════════
REDIS_URL=redis://:redis_password@localhost:{{REDIS_PORT}}
REDIS_PASSWORD=redis_password

# ═══════════════════════════════════════
# Authentication
# ═══════════════════════════════════════
<!-- IF {{AUTH_METHOD}} == "jwt" -->
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRATION=7d
<!-- ENDIF -->

# ═══════════════════════════════════════
# API
# ═══════════════════════════════════════
API_PORT={{BACKEND_PORT}}
API_PREFIX={{API_PREFIX}}

# ═══════════════════════════════════════
# Frontend
# ═══════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:{{BACKEND_PORT}}{{API_PREFIX}}

# ═══════════════════════════════════════
# External Services (optional)
# ═══════════════════════════════════════
# SENDGRID_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# STRIPE_SECRET_KEY=
